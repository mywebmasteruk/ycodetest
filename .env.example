# Multi-tenant MasjidWeb: UUID for this site (matches tenant_registry). Used to scope `settings`
# when the DB has unique (tenant_id, key). Falls back to MASTER_TENANT_ID / TEMPLATE_TENANT_ID if unset.
TENANT_ID=
# MASTER_TENANT_ID=
# TEMPLATE_TENANT_ID=

# Supabase credentials
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
SUPABASE_CONNECTION_URL=
SUPABASE_DB_PASSWORD=

# Templates API
NEXT_PUBLIC_TEMPLATE_API_URL=
TEMPLATE_API_URL=
TEMPLATE_UPLOAD_API_KEY=

# Secret key for signing page auth cookies (can be generated using `openssl rand -hex 32`)
PAGE_AUTH_SECRET=

# Google Fonts API Key (only to used to execute `npm run fonts:update`)
GOOGLE_FONTS_API_KEY=

# Netlify (production): SITE_ID is set automatically on Functions. Optional: personal access
# token with cache purge permission — instant CDN invalidation after Publish (see lib/services/cacheService.ts).
# NETLIFY_PURGE_API_TOKEN=

# Proxy: short-lived in-memory cache for subdomain → tenant_registry lookup (per serverless instance).
# Does not affect published HTML freshness. Use 0 to disable success caching. Provisioning publish always bypasses.
# TENANT_LOOKUP_CACHE_SUCCESS_MS=4000
# TENANT_LOOKUP_CACHE_MISS_MS=2000
