# Template tenant UUID — same value as admin-dashboard-v2 TEMPLATE_TENANT_ID.
# Used by middleware to resolve the master builder subdomain.
TEMPLATE_TENANT_ID=

# Optional; default "manage"
MASTER_BUILDER_SUBDOMAIN=manage

# Tenant sites live on *.<suffix> (middleware). Set both so auth cookies are shared
# across subdomains and the apex (invite links / Site URL mismatches).
# Example: masjidweb.com
TENANT_DOMAIN_SUFFIX=
NEXT_PUBLIC_TENANT_DOMAIN_SUFFIX=

# Same secret as admin-dashboard-v2 — provisioning publish webhook (16+ chars).
# PROVISIONING_WEBHOOK_SECRET=

# Supabase credentials
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
SUPABASE_CONNECTION_URL=
SUPABASE_DB_PASSWORD=

# Templates API
NEXT_PUBLIC_TEMPLATE_API_URL=
TEMPLATE_API_URL=
TEMPLATE_UPLOAD_API_KEY=

# Secret key for signing page auth cookies (can be generated using `openssl rand -hex 32`)
PAGE_AUTH_SECRET=

# Google Fonts API Key (only to used to execute `npm run fonts:update`)
GOOGLE_FONTS_API_KEY=
